# Public / parity p2p container environment
# Run with:
# docker compose --env-file deploy/container/public.p2p.env.example -f deploy/container/docker-compose.public.p2p.yml up --build
#
# For localhost parity testing with this file, replace the example domains below with:
# - VITE_P2P_SIGNALING_URL=http://localhost:3002
# - SIGNALING_ALLOWED_ORIGINS=http://localhost:8080
# - CSP_CONNECT_SRC=http://localhost:3002

DEPLOYMENT_MODE=public

CLIENT_PUBLIC_PORT=8080
SIGNALING_PUBLIC_PORT=3002

VITE_DEPLOYMENT_MODE=p2p
VITE_P2P_SIGNALING_URL=https://signal.example.com
CSP_CONNECT_SRC=https://signal.example.com
SIGNALING_ALLOWED_ORIGINS=https://app.example.com
TRUST_PROXY=true

SIGNALING_REDIS_KEY_PREFIX=minesweeper-flags-public:signaling
P2P_SIGNALING_SESSION_TTL_SECONDS=900
P2P_SIGNALING_MAX_PAYLOAD_BYTES=16384
VITE_P2P_STUN_URLS=stun:stun.l.google.com:19302

SIGNALING_CREATE_RATE_LIMIT_MAX=6
SIGNALING_CREATE_RATE_LIMIT_WINDOW_MS=60000
SIGNALING_ANSWER_RATE_LIMIT_MAX=12
SIGNALING_ANSWER_RATE_LIMIT_WINDOW_MS=60000
SIGNALING_RECONNECT_RATE_LIMIT_MAX=240
SIGNALING_RECONNECT_RATE_LIMIT_WINDOW_MS=60000
