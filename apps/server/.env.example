# Example server environment variables.
# The current Node server does not auto-load .env files.
# Use these values as a template for your shell, container platform, or Compose config.

# Network
DEPLOYMENT_MODE=local
PORT=3001
HOST=0.0.0.0
WS_PATH=/ws

# Public websocket hardening
# Leave blank for lightweight local development.
# For parity-local or public deploys, set a comma-separated allowlist such as:
# WEBSOCKET_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
WEBSOCKET_ALLOWED_ORIGINS=
MAX_WEBSOCKET_MESSAGE_BYTES=16384

# Proxy awareness
# Set to true only when the app is behind a trusted proxy or load balancer
# that correctly sets X-Forwarded-For.
TRUST_PROXY=false

# Abuse controls
MAX_CONNECTIONS_PER_IP=6
MAX_CONCURRENT_ROOMS=4
ROOM_CREATE_RATE_LIMIT_MAX=4
ROOM_CREATE_RATE_LIMIT_WINDOW_MS=60000
ROOM_JOIN_RATE_LIMIT_MAX=10
ROOM_JOIN_RATE_LIMIT_WINDOW_MS=60000
INVALID_MESSAGE_RATE_LIMIT_MAX=5
INVALID_MESSAGE_RATE_LIMIT_WINDOW_MS=30000
SOCKET_HEARTBEAT_INTERVAL_MS=30000

# Shared state backend
# Supported values: memory, redis.
# Use redis for parity-local and public deployments.
STATE_BACKEND=memory

# Redis settings
# Required when STATE_BACKEND=redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=minesweeper-flags
RECONNECT_SESSION_TTL_SECONDS=1800
