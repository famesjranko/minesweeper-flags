# Example client build-time environment variables for Vite.
# Vite reads .env files from the client app directory during the client build.

# Choose the deployment style this client build should support.
VITE_DEPLOYMENT_MODE=server

# Required for server deployments on non-local frontend hosts.
# Leave unset only for make dev or the convenience same-origin Compose stack.
VITE_SOCKET_URL=wss://api.example.com/ws

# Optional socket path used for same-origin fallback.
VITE_SOCKET_PATH=/ws

# Optional in server mode. Required when VITE_DEPLOYMENT_MODE=p2p.
VITE_P2P_SIGNALING_URL=https://signal.example.com

# Optional comma-separated STUN server URLs for p2p mode.
VITE_P2P_STUN_URLS=stun:stun.l.google.com:19302
