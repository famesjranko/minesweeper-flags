# Example client build-time environment variables for Vite.
# Vite reads .env files from the client app directory during the client build.
# Parity-local and public frontend builds should set VITE_SOCKET_URL explicitly.

# Required for non-local frontend deployments.
# Leave unset only for make dev or the convenience same-origin Compose stack.
VITE_SOCKET_URL=wss://api.example.com/ws

# Optional socket path used for same-origin fallback.
VITE_SOCKET_PATH=/ws
